   ],
   "source": [
    "class Programmer:\n",
    "    company = \"Microsoft\"\n",
    "    def __init__(self,name,pin,salary):\n",
    "        self.name = name\n",
    "        self.pin = pin\n",
    "        self.salary = salary\n",
    "\n",
    "p = Programmer(\"Harry\", 1231, 1400000)\n",
    "print(p.name, p.pin, p.salary, p.company)       \n",
    "r = Programmer(\"Rohan\", 2341, 1200000)\n",
    "print(r.name, r.pin, r.salary, r.company)\n"
   ]
