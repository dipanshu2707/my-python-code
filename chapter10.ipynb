   "source": [
    "2. Write a class \"calculator\" capable of finding square, cube and square root of a number."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "5fe05941",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "the square is 9\n",
      "the cube is 27\n",
      "the square root is 1.7320508075688772\n"
     ]
    }
   ],
   "source": [
    "class calculator:\n",
    "    def __init__(self, n):\n",
    "        self.n = n\n",
    "\n",
    "    def square(self):\n",
    "        print(f\"the square is {self.n*self.n}\")\n",
    "\n",
    "    def cube(self):\n",
    "        print(f\"the cube is {self.n*self.n*self.n}\")\n",
    "\n",
    "    def square_root(self):\n",
    "        print(f\"the square root is {self.n**0.5}\")          \n",
    "\n",
    "\n",
    "a = calculator(3)\n",
    "a.square()  \n",
    "a.cube()\n",
    "a.square_root()        "
   ]
  },
