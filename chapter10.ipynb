    "5. Write a class train which has methode to book a ticket get status (no of seats) and get fare information to train running under Indian Railways."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "65e3d052",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Ticket is booked in train no:12345 from Delhi to Mumbai\n",
      "Train no12345 is running on time\n",
      "Ticket is booked in train no:12345 from Delhi to Mumbai is 2124\n"
     ]
    }
   ],
   "source": [
    "from random import randint\n",
    "\n",
    "class Train:\n",
    "    def book(self, train_no, fro, to):\n",
    "        print(f\"Ticket is booked in train no:{train_no} from {fro} to {to}\")\n",
    "        \n",
    "\n",
    "    def getStatus(self, train_no):\n",
    "        print(f\"Train no{train_no} is running on time\")\n",
    "\n",
    "    def getFare(self, train_no , fro, to):\n",
    "        print(f\"Ticket is booked in train no:{train_no} from {fro} to {to} is {randint(222,5555)}\")\n",
    "\n",
    "t = Train()\n",
    "t.book(12345, \"Delhi\", \"Mumbai\")\n",
    "t.getStatus(12345)\n",
    "t.getFare(12345, \"Delhi\", \"Mumbai\")"
   ]
